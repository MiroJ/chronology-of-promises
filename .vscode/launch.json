{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug in Edge",
            "type": "msedge",
            "request": "launch",
            "webRoot": "${workspaceFolder}",
            "url": "http://localhost:4200",
            "preLaunchTask": "npm: start",
            "sourceMapPathOverrides": {
                "webpack:///./src/*": "${webRoot}/*",
                "webpack:///src/*": "${webRoot}/*",
                "webpack:///*": "*",
                "./*": "${webRoot}/*"
            }
        }
    ]
}
